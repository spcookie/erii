# LLM API 配置
GOOGLE_API_KEY=your_google_api_key_here
DEEP_SEEK_API_KEY=your_deep_seek_api_key_here
MINIMAX_CODING_PLAN_KEY=your_minimax_api_key_here
CHOICE_MODEL=MINIMAX# GOOGLE / DEEP_SEEK / MINIMAX

# Embedding 配置（可选，用于记忆系统）
EMBEDDING_API_KEY=your_bytedance_embedding_key_here

# 搜索配置（可选，用于 QA 插件）
SEARCH_API_KEY=your_exa_search_key_here

# NapCat Token
NAPCAT_TOKEN=your_napcat_token

# 浏览器服务（可选，用于网页截图/Markdown 抓取）
PLAYWRIGHT_HOST=ws://127.0.0.1:13001

# 代理配置（可选）
HTTP_PROXY=http://127.0.0.1:7899
SOCKS_PROXY=http://127.0.0.1:7898

# NapCat UID/GID（Docker 部署时使用）
NAPCAT_UID=your_uid
NAPCAT_GID=your_gid
