# LLM 配置
llm {
  choice-model = "MINIMAX"  # GOOGLE / DEEP_SEEK / MINIMAX

  google {
    api-key = ${?GOOGLE_API_KEY}
    base-url = "https://generativelanguage.googleapis.com"
    models {
      lite = "gemini-2.0-flash-lite"
      flash = "gemini-2.0-flash"
      pro = "gemini-2.5-pro"
    }
  }
  deep-seek {
    api-key = ${?DEEP_SEEK_API_KEY}
    base-url = "https://api.deepseek.com"
    models {
      lite = "deepseek-chat"
      flash = "deepseek-chat"
      pro = "deepseek-chat"
    }
  }
  minimax {
    api-key = ${?MINIMAX_CODING_PLAN_KEY}
    base-url = "https://api.minimaxi.com"
    models {
      lite = "MiniMax-M2.5"
      flash = "MiniMax-M2.5"
      pro = "MiniMax-M2.7"
    }
  }
}

# Embedding 配置（用于记忆系统）
embedding {
  api-key = ${?EMBEDDING_API_KEY}
  provider = "bytedance"
}

# Search 配置（用于 QA 插件）
search {
  api-key = ${?SEARCH_API_KEY}
  provider = "exa"
}

# Browser 相关配置（用于网页截图/Markdown 抓取）
browser {
  playwright-host = ${?PLAYWRIGHT_HOST}
  status-host = ${?STATUS_HOST}
}

# 代理配置
proxy {
  http = ${?HTTP_PROXY}
  socks = ${?SOCKS_PROXY}
}

# OneBot QQ Bot 配置
onebot {
  bots = {
    your_bot = {
      ws = "ws://127.0.0.1:3001"  # NapCat WebSocket 地址
      token = ${NAPCAT_TOKEN}
      role-id = "YourBotRole"      # 对应的角色 ID（在 BotRoleManager 中配置）
      groups = {
        123456789 = {              # 群组 ID
          admins = []              # 群管理员列表
          desire = 15
        }
      }
      # 可选：按机器人维度覆盖全局 groups 配置
      # 未指定的字段回退到全局 groups 配置；message-redirect-map 与全局合并，本机器人配置优先
      # groups-override = {
      #   enable-groups = [123456789]          # 覆盖：此机器人仅响应这些群
      #   debug-group-id = null                # 覆盖：此机器人的调试群（null 则用全局）
      #   message-redirect-map = {}            # 合并：与全局 map 合并，本级优先
      # }
      # 可选：插件白名单/黑名单（白名单优先）
      # enabled-plugins = ["seeddream", "qa"]     # 仅启用这些插件（其余插件禁用）
      # disabled-plugins = ["lolisuki", "animal"] # 禁用这些插件（其余插件启用）
    }
  }
}

# 群组配置
groups {
  debug-group-id = null                    # 调试群组（可选，设为 null 则不启用）
  enable-groups = [123456789, 987654321]  # 启用的群组列表
  message-redirect-map = []                # 消息重定向映射，格式：sourceGroup:targetGroup
}
