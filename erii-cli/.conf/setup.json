{
  "providers": [
    {
      "name": "Google",
      "key": "google",
      "desc": "Google Gemini models",
      "base-url": "https://generativelanguage.googleapis.com"
    },
    {
      "name": "DeepSeek",
      "key": "deep-seek",
      "desc": "DeepSeek models",
      "base-url": "https://api.deepseek.com"
    },
    {
      "name": "MiniMax",
      "key": "minimax",
      "desc": "MiniMax models (Anthropic-compatible API)",
      "base-url": "https://api.minimaxi.com"
    },
    {
      "name": "OpenAI",
      "key": "openai",
      "desc": "OpenAI models",
      "base-url": "https://api.openai.com/v1"
    },
    {
      "name": "Anthropic",
      "key": "anthropic",
      "desc": "Anthropic Claude models",
      "base-url": "https://api.anthropic.com"
    },
    {
      "name": "OpenRouter",
      "key": "openrouter",
      "desc": "OpenRouter - unified API for multiple LLM providers",
      "base-url": "https://openrouter.ai/api"
    }
  ],
  "defaults": {
    "llm": {
      "google": {
        "model-mode": "separate",
        "lite-model": "gemini-2.0-flash-lite",
        "flash-model": "gemini-2.0-flash",
        "pro-model": "gemini-2.5-pro",
        "all-model": "gemini-2.5-pro"
      },
      "deep-seek": {
        "model-mode": "all",
        "all-model": "deepseek-chat"
      },
      "minimax": {
        "model-mode": "separate",
        "lite-model": "MiniMax-M2.5",
        "flash-model": "MiniMax-M2.5",
        "pro-model": "MiniMax-M2.7",
        "all-model": "MiniMax-M2.7"
      },
      "openai": {
        "model-mode": "separate",
        "lite-model": "gpt-4.1-nano",
        "flash-model": "gpt-4.1-mini",
        "pro-model": "gpt-4.1",
        "all-model": "gpt-4.1"
      },
      "anthropic": {
        "model-mode": "separate",
        "lite-model": "claude-haiku-4-5-20251001",
        "flash-model": "claude-sonnet-4-6",
        "pro-model": "claude-sonnet-4-6",
        "all-model": "claude-sonnet-4-6"
      },
      "openrouter": {
        "model-mode": "separate",
        "lite-model": "openai/gpt-4.1-nano",
        "flash-model": "openai/gpt-4.1-mini",
        "pro-model": "anthropic/claude-sonnet-4-6",
        "all-model": "anthropic/claude-sonnet-4-6"
      }
    },
    "bot": {
      "ws": "ws://127.0.0.1:3001",
      "token": ""
    },
    "groups": {
      "debug-group-id": "",
      "enable-groups": "",
      "message-redirect-map": ""
    },
    "browser": {
      "download": false,
      "playwright-url": "ws://127.0.0.1:13001",
      "external-host": "localhost"
    },
    "proxy": {
      "http": "",
      "socks": ""
    }
  },
  "tool-providers": {
    "embedding": [
      {
        "name": "ByteDance",
        "url": "https://ark.cn-beijing.volces.com/api/v3/embeddings/multimodal",
        "model": "doubao-embedding-vision-250615"
      },
      {
        "name": "SiliconFlow",
        "url": "https://api.siliconflow.cn/v1/embeddings",
        "model": "BAAI/bge-m3"
      }
    ],
    "search": [
      {
        "name": "Exa",
        "url": "https://api.exa.ai/search"
      },
      {
        "name": "MiniMax",
        "url": "https://api.minimaxi.com/v1/coding_plan/search"
      }
    ],
    "vision": [
      {
        "name": "MiniMax",
        "url": "https://api.minimaxi.com/v1/coding_plan/vlm"
      }
    ],
    "browser": [
      {
        "name": "Playwright",
        "url": "ws://127.0.0.1:13001"
      }
    ]
  }
}
