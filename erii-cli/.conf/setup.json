{
  "providers": [
    {
      "name": "OpenAI",
      "key": "openai",
      "desc": "OpenAI models",
      "base-url": "https://api.openai.com/v1"
    },
    {
      "name": "Anthropic",
      "key": "anthropic",
      "desc": "Anthropic Claude models",
      "base-url": "https://api.anthropic.com"
    }
  ],
  "defaults": {
    "llm": {
      "openai": {
        "model-mode": "separate",
        "lite-model": "gpt-4.1-nano",
        "flash-model": "gpt-4.1-mini",
        "pro-model": "gpt-4.1",
        "all-model": "gpt-4.1"
      },
      "anthropic": {
        "model-mode": "separate",
        "lite-model": "claude-haiku-4-5-20251001",
        "flash-model": "claude-sonnet-4-6",
        "pro-model": "claude-sonnet-4-6",
        "all-model": "claude-sonnet-4-6"
      }
    },
    "bot": {
      "ws": "ws://127.0.0.1:3001",
      "token": ""
    },
    "groups": {
      "debug-group-id": "",
      "enable-groups": "",
      "message-redirect-map": ""
    },
    "browser": {
      "download": true,
      "playwright-url": "ws://127.0.0.1:3001",
      "external-host": "localhost"
    },
    "proxy": {
      "http": "",
      "socks": ""
    }
  },
  "tool-providers": {
    "embedding": [
      {
        "name": "ByteDance",
        "url": "https://ark.cn-beijing.volces.com/api/v3/embeddings/multimodal",
        "model": "doubao-embedding-vision-250615"
      },
      {
        "name": "SiliconFlow",
        "url": "https://api.siliconflow.cn/v1/embeddings",
        "model": "BAAI/bge-m3"
      }
    ],
    "search": [
      {
        "name": "Ark",
        "url": "https://ark.cn-beijing.volces.com/api/v1/responses"
      },
      {
        "name": "Exa",
        "url": "https://api.exa.ai/search"
      },
      {
        "name": "MiniMax",
        "url": "https://api.minimaxi.com/v1/coding_plan/search"
      }
    ],
    "vision": [
      {
        "name": "Ark",
        "url": "https://ark.cn-beijing.volces.com/api/v3/responses"
      },
      {
        "name": "MiniMax",
        "url": "https://api.minimaxi.com/v1/coding_plan/vlm"
      }
    ],
    "browser": [
      {
        "name": "Playwright",
        "url": "ws://127.0.0.1:3001"
      }
    ]
  }
}
