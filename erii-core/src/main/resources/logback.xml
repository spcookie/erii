<configuration>

    <!-- 抑制 logback 内部状态输出 -->
    <statusListener class="ch.qos.logback.core.status.NopStatusListener"/>

    <!-- 日志目录 -->
    <property name="LOG_HOME" value="./logs"/>

    <!-- Console 输出（非 CLI 模式使用） -->
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>
                %date{yyyy-MM-dd HH:mm:ss} %highlight(%-5level) %gray([%thread]) %boldMagenta(%logger{50}) %msg%n
            </pattern>
        </encoder>
    </appender>

    <!-- ERROR 文件输出 -->
    <appender name="ERROR_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_HOME}/error.log</file>
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>ERROR</level>
        </filter>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${LOG_HOME}/error.%d{yyyy-MM-dd}.log.gz</fileNamePattern>
            <maxHistory>15</maxHistory>
            <totalSizeCap>2GB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>
                %date{yyyy-MM-dd HH:mm:ss} %-5level [%thread] %logger{50} - %msg%n%ex
            </pattern>
        </encoder>
    </appender>

    <!-- INFO 文件输出（CLI 模式使用） -->
    <appender name="INFO_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_HOME}/info.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${LOG_HOME}/info.%d{yyyy-MM-dd}.log.gz</fileNamePattern>
            <maxHistory>15</maxHistory>
            <totalSizeCap>2GB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>
                %date{yyyy-MM-dd HH:mm:ss} %-5level [%thread] %logger{50} - %msg%n%ex
            </pattern>
        </encoder>
    </appender>

    <!-- 非 CLI 模式：控制台 + ERROR 文件 -->
    <if>
        <condition>!"CLI".equals(property("ERII_START_MODE"))</condition>
        <then>
            <root level="INFO">
                <appender-ref ref="STDOUT"/>
                <appender-ref ref="ERROR_FILE"/>
            </root>
        </then>
    </if>

    <!-- CLI 模式：所有日志写入文件，不输出控制台 -->
    <if>
        <condition>"CLI".equals(property("ERII_START_MODE"))</condition>
        <then>
            <root level="INFO">
                <appender-ref ref="INFO_FILE"/>
                <appender-ref ref="ERROR_FILE"/>
            </root>
        </then>
    </if>

    <logger name="io.ktor" level="INFO"/>
    <logger name="io.netty" level="INFO"/>

</configuration>
